// ─── MOVIE CARD ──────────────────────────────────────────────────────────────

function MovieCard({ movie, ranked, rank, progress }) {
  const [hovered, setHovered] = useState(false);

  // Generate a repeatable gradient based on movie id
  const hue1 = (movie.id * 47) % 360;
  const hue2 = (movie.id * 83 + 120) % 360;

  return (
    <div
      className="relative flex-shrink-0 cursor-pointer group"
      style={{ width: ranked ? 180 : 200 }}
      onMouseEnter={() => setHovered(true)}
      onMouseLeave={() => setHovered(false)}
    >
      {/* Rank number */}
      {ranked && (
        <span
          style={{
            position: "absolute",
            left: -28,
            bottom: 0,
            fontSize: 90,
            fontWeight: 900,
            lineHeight: 1,
            color: "transparent",
            WebkitTextStroke: "2px rgba(255,255,255,0.18)",
            fontFamily: "'Arial Black', sans-serif",
            zIndex: 2,
            userSelect: "none",
          }}
        >
          {rank}
        </span>
      )}

      {/* Poster */}
      <div
        style={{
          width: "100%",
          aspectRatio: ranked ? "2/3" : "16/9",
          borderRadius: 8,
          overflow: "hidden",
          background: `linear-gradient(135deg, hsl(${hue1},60%,12%) 0%, hsl(${hue2},50%,8%) 100%)`,
          border: hovered ? "2px solid rgba(255,255,255,0.5)" : "2px solid transparent",
          transition: "border 0.2s, transform 0.2s, box-shadow 0.2s",
          transform: hovered ? "scale(1.04)" : "scale(1)",
          boxShadow: hovered ? `0 8px 32px hsla(${hue1},60%,30%,0.5)` : "none",
          position: "relative",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
        }}
      >
        {/* Faux poster art */}
        <div style={{ opacity: 0.25, fontSize: 48, userSelect: "none" }}>🎬</div>

        {/* Title overlay on thumbnail */}
        <div
          style={{
            position: "absolute",
            bottom: 0,
            left: 0,
            right: 0,
            padding: "24px 10px 8px",
            background: "linear-gradient(to top, rgba(0,0,0,0.85), transparent)",
            fontSize: 12,
            fontWeight: 700,
            color: "#fff",
            lineHeight: 1.3,
          }}
        >
          {movie.title}
        </div>

        {/* Badge */}
        {movie.badge && (
          <div
            style={{
              position: "absolute",
              top: 8,
              left: 8,
              background:
                movie.badge === "HBO"
                  ? "#fff"
                  : movie.badge === "NEW" || movie.badge.startsWith("NEW")
                  ? "#1ac8f5"
                  : movie.badge === "OSCAR"
                  ? "#f5c518"
                  : movie.badge === "DAILY"
                  ? "#e84393"
                  : "#e50914",
              color:
                movie.badge === "HBO" || movie.badge === "OSCAR" ? "#000" : "#fff",
              fontSize: 9,
              fontWeight: 900,
              padding: "2px 6px",
              borderRadius: 3,
              letterSpacing: 0.5,
            }}
          >
            {movie.badge}
          </div>
        )}

        {/* Progress bar */}
        {progress && (
          <div
            style={{
              position: "absolute",
              bottom: 0,
              left: 0,
              right: 0,
              height: 3,
              background: "rgba(255,255,255,0.2)",
            }}
          >
            <div
              style={{
                height: "100%",
                width: `${progress}%`,
                background: "#1ac8f5",
                borderRadius: 2,
              }}
            />
          </div>
        )}

        {/* Play on hover */}
        {hovered && (
          <div
            style={{
              position: "absolute",
              inset: 0,
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              background: "rgba(0,0,0,0.35)",
            }}
          >
            <div
              style={{
                width: 44,
                height: 44,
                borderRadius: "50%",
                background: "rgba(255,255,255,0.15)",
                border: "2px solid rgba(255,255,255,0.8)",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                backdropFilter: "blur(4px)",
              }}
            >
              <span style={{ fontSize: 18, marginLeft: 3 }}>▶</span>
            </div>
          </div>
        )}
      </div>

      {/* Info below */}
      <div style={{ padding: "6px 2px 0" }}>
        <div style={{ fontSize: 13, fontWeight: 600, color: "#e8e8e8", lineHeight: 1.3 }}>
          {movie.title}
        </div>
        <div style={{ fontSize: 11, color: "#888", marginTop: 2 }}>{movie.info}</div>
      </div>
    </div>
  );
}

