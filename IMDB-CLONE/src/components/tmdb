        style={{
          position: "absolute",
          right: 0,
          top: 0,
          bottom: 0,
          width: "55%",
          background: `linear-gradient(135deg, hsla(${hue},70%,18%,0.6) 0%, hsla(${(hue+60)%360},50%,10%,0.4) 100%)`,
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          fontSize: 180,
          opacity: 0.15,
          userSelect: "none",
