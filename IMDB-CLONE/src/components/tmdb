      {/* Animated background gradient */}
      <div
        style={{
          position: "absolute",
          inset: 0,
          background: `
            radial-gradient(ellipse 70% 80% at 30% 50%, hsla(${hue},80%,20%,0.7) 0%, transparent 70%),
            radial-gradient(ellipse 50% 60% at 75% 40%, hsla(${(hue + 40) % 360},60%,15%,0.5) 0%, transparent 60%),
            linear-gradient(to right, #000 20%, transparent 60%)
